generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash String
  name      String
  role      Role
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  DRIVER
  PARTNER
  CLIENT
}

enum OrganizationType {
  CHAUFFEUR
  SECURITY
}

model Organizations {
  id             String           @id @default(uuid())
  organizationName          String
  email          String           @unique
  phone          String           @unique
  contactPerson  String
  serviceAreas    String           @default("")
  status         Boolean
  type           OrganizationType
  createdAt      DateTime         @default(now())


  drivers        Drivers[]
  vehicles       Vehicles[]
  chauffeurDetails  ChauffeurOrganizationDetails?
  securityDetails   SecurityOrganizationDetails?
  securityAgents    SecurityAgents[]

  @@index([type])
}

model ChauffeurOrganizationDetails {
  id                            String         @id @default(uuid())
  organizationId                String         @unique
  organization                  Organizations  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Company Information
  legalForm                     String?
  sirenOrSiret                  String?
  vatNumber                     String?
  registrationDate              DateTime?
  registrationCountry           String?        @default("France")
  registeredAddress             String?
  mailingAddress                String?
  sameAsRegisteredAddress       Boolean        @default(false)
  websiteUrl                    String?
  directorFullName              String?
  directorPosition              String?

  // Documents metadata
  kbisUploaded                  Boolean        @default(false)
  rcProInsuranceUploaded        Boolean        @default(false)
  transportInsuranceUploaded    Boolean        @default(false)
  operatingLicenseProvided      Boolean        @default(false)
  bankDetailsProvided           Boolean        @default(false)
  directorIdCopyProvided        Boolean        @default(false)
  signedPartnershipAgreement    Boolean        @default(false)
  additionalCertifications      String?
  documentNotes                 String?

  // Operations
  serviceTypes                  String[]       @default([])
  workingHours                  String?
  support24_7                   Boolean        @default(false)
  languagesSpoken               String[]       @default([])
  maxConcurrentBookings         Int?
  minAdvanceBookingHours        Int?
  acceptsUrgentBookings         Boolean        @default(false)
  cancellationPolicy            String?
  specialConditionsNotes        String?

  // Commercial & Financial
  cooperationType               CooperationType?
  bankAccountIban               String?
  paymentTerms                  String?
  commissionPercent             Decimal?       @db.Decimal(5, 2)
  currency                      String?        @default("EUR")
  minimumFare                   Decimal?       @db.Decimal(10, 2)
  hourlyRate                    Decimal?       @db.Decimal(10, 2)
  transferBaseRate              Decimal?       @db.Decimal(10, 2)
  nightSurchargePercent         Decimal?       @db.Decimal(5, 2)
  holidaySurchargePercent       Decimal?       @db.Decimal(5, 2)
  waitingTimeFee                Decimal?       @db.Decimal(10, 2)

  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@index([organizationId])
}

enum DriverStatus {
  AVAILABLE
  ON_RIDE
  OFFLINE
}

enum CooperationType {
  COMMISSION
  FIXED_RATE
  CUSTOM
}

enum EmploymentStatus {
  EMPLOYEE
  FREELANCE
  SUBCONTRACTOR
}

model Drivers {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // BASIC
  name           String
  phone          String?
  email          String?
  address        String?
  nationality    String?
  birthDate      DateTime?
  languages      String[]     @default([])
  emergencyContact String?

  // PROFESSIONAL
  employmentStatus     EmploymentStatus?
  vtcCardNumber        String?
  vtcCardIssuedAt      DateTime?
  vtcCardExpiresAt     DateTime?
  driverLicenseNumber  String?
  licenseCategory      String?
  licenseIssuedAt      DateTime?
  licenseExpiresAt     DateTime?
  drivingExperienceYears Int?
  hasVipExperience     Boolean @default(false)
  hasEventExperience   Boolean @default(false)
  languageLevel        String?
  dressCodeReady       Boolean @default(false)

  // DOCUMENTS (metadata)
  passportProvided           Boolean @default(false)
  driverLicenseProvided      Boolean @default(false)
  vtcCardProvided            Boolean @default(false)
  criminalRecordProvided     Boolean @default(false)
  medicalCertificateProvided Boolean @default(false)
  insuranceProofProvided     Boolean @default(false)
  profilePhotoProvided       Boolean @default(false)
  signedContractProvided     Boolean @default(false)

  // OPERATIONS
  baseCity                   String?
  workingRadiusKm            Int?
  acceptsLongDistance        Boolean @default(false)
  acceptsNightTrips          Boolean @default(false)
  acceptsAirportTransfers    Boolean @default(false)
  acceptsVipClients          Boolean @default(false)
  availabilityDays           String[] @default([])
  availabilityHours          String?
  hasOwnVehicle              Boolean @default(false)

  // EXISTING FIELDS (залишаємо)
  vehicle        String
  vehiclePlate   String
  vehicleColor   String
  status         DriverStatus @default(AVAILABLE)
  rides          Int          @default(0)
  todayShift     String       @default("")

  assignedVehicles Vehicles[]
  bookings       Bookings[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

enum VehicleClass {
  COMFORT
  BUSINESS
  VAN
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
}

model Vehicles {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driverId       String?
  driver         Drivers?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicleName    String
  yearColor      String
  licensePlate   String        @unique
  class          VehicleClass
  status         VehicleStatus @default(AVAILABLE)
  nextService    String        @default("")
  pricing        VehiclePricings?
  bookings       Bookings[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model VehiclePricings {
  id         String   @id @default(uuid())
  vehicleId  String   @unique
  vehicle    Vehicles @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  perHour    Decimal  @db.Decimal(10, 2)
  perKm      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum PhysicalLevel {
  LOW
  MEDIUM
  HIGH
}

enum AgentAvailabilityStatus {
  AVAILABLE
  ON_ASSIGNMENT
  OFF_DUTY
}

model Bookings {
  id            String        @id @default(uuid())
  clientName    String
  vehicleId     String
  vehicle       Vehicles      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        Drivers?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  bookingAt     DateTime
  route         String        @default("")
  durationMin   Int           @default(60)
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([vehicleId])
  @@index([driverId])
  @@index([bookingAt])
}

model SecurityOrganizationDetails {
  id               String        @id @default(uuid())
  organizationId   String        @unique
  organization     Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Company Information
  companyName                String?
  legalForm                  String?
  sirenOrSiret               String?
  licenseNumber              String? // autorisation d’exercice
  cnapsNumber                String?
  registrationDate           DateTime?
  registeredAddress          String?
  officeAddress              String?
  websiteUrl                 String?
  generalEmail               String?
  companyPhoneNumber         String?
  directorFullName           String?
  primaryContactName         String?
  primaryContactEmail        String?
  primaryContactPhone        String?

  // Documents metadata
  kbisUploaded               Boolean @default(false)
  licenseUploaded            Boolean @default(false) // autorisation
  rcProInsuranceUploaded     Boolean @default(false)
  cnapsAuthorizationUploaded Boolean @default(false)
  bankDetailsProvided        Boolean @default(false)
  directorIdCopyProvided     Boolean @default(false)
  signedPartnershipAgreement Boolean @default(false)
  additionalCertifications   String?

  // Operations
  serviceAreas               String?
  serviceTypes               String[] @default([])
  support24_7                Boolean @default(false)
  minBookingHours            Int?
  mobilizationTimeMinutes    Int?
  agentsCount                Int?
  languagesSpoken            String[] @default([])
  hasTeamLeader              Boolean @default(false)
  armedPersonnelAllowed      Boolean @default(false)
  unarmedPersonnelAllowed    Boolean @default(true)
  internationalMissions      Boolean @default(false)
  specialRequirements        String?

  // Financial
  hourlyRate                 Decimal? @db.Decimal(10, 2)
  dailyRate                  Decimal? @db.Decimal(10, 2)
  nightRate                  Decimal? @db.Decimal(10, 2)
  eventRate                  Decimal? @db.Decimal(10, 2)
  executiveProtectionRate    Decimal? @db.Decimal(10, 2)
  minimumBookingAmount       Decimal? @db.Decimal(10, 2)
  commissionPercent          Decimal? @db.Decimal(5, 2)
  paymentTerms               String?
  bankAccountIban            String?
  currency                   String?  @default("EUR")

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([organizationId])
}

model SecurityAgents {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // PERSONAL
  firstName       String
  lastName        String
  birthDate       DateTime?
  nationality     String?
  profilePhotoUrl String?
  phone           String?
  email           String?
  address         String?
  languages       String[] @default([])
  emergencyContact String?

  // PROFESSIONAL
  employmentStatus       EmploymentStatus?
  professionalCardNumber String?
  cnapsNumber            String?
  cardIssuedAt           DateTime?
  cardExpiresAt          DateTime?

  specializations        String[] @default([])

  experienceYears        Int?
  hasVipExperience       Boolean @default(false)
  hasEventExperience     Boolean @default(false)

  hasDriverLicenseB      Boolean @default(false)
  additionalLicenses     String?

  physicalLevel          PhysicalLevel?
  hasFirstAidTraining    Boolean @default(false)
  weaponExperience       Boolean @default(false)

  readyForTravel         Boolean @default(false)
  readyForNightShifts    Boolean @default(false)

  // DOCUMENTS (metadata)
  passportProvided            Boolean @default(false)
  professionalCardProvided    Boolean @default(false)
  cnapsProvided               Boolean @default(false)
  cvProvided                  Boolean @default(false)
  certificatesProvided        Boolean @default(false)
  firstAidCertificateProvided Boolean @default(false)
  driverLicenseProvided       Boolean @default(false)
  backgroundCheckProvided     Boolean @default(false)
  profilePhotoProvided        Boolean @default(false)
  signedContractProvided      Boolean @default(false)

  // OPERATIONS
  baseCity               String?
  workingRadiusKm        Int?
  availability           String?

  hourlyRate             Decimal? @db.Decimal(10, 2)
  dailyRate              Decimal? @db.Decimal(10, 2)
  nightRate              Decimal? @db.Decimal(10, 2)

  canWorkInTeam          Boolean @default(true)
  canTravelWithClient    Boolean @default(true)
  canDoDriverSecurity    Boolean @default(false)

  availabilityStatus AgentAvailabilityStatus @default(AVAILABLE)
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}