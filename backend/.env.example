# Copy to .env and adjust.
DATABASE_URL=postgresql://postgres:password@localhost:5432/aurevia_admin

JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long
FRONTEND_ORIGIN=http://localhost:5173
LANDING_ORIGIN=http://localhost:3000
# Optional override: comma-separated list replaces FRONTEND_ORIGIN / LANDING_ORIGIN for CORS.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://booking.example.com
PORT=5000
# Public API origin for uploaded file URLs (no /api suffix). Landing uses imageUrl from API.
API_PUBLIC_ORIGIN=http://localhost:5000
# Optional custom uploads directory (default: backend/uploads)
# UPLOADS_DIR=

# Optional: if set, public landing must send header x-public-booking-key: <same value>
# PUBLIC_BOOKING_API_KEY=

# Optional: polling interval for driver-deadline fallback watcher (min 5000 ms)
# DRIVER_DEADLINE_WATCH_INTERVAL_MS=60000
# Driver/payment windows: urgent <1h, standard 1h–3d, advance >3d; payment max 72h after accept (booking.deadlines.ts).
# Display timezone for deadlines in emails and WhatsApp:
# BOOKING_DISPLAY_TIMEZONE=Europe/Paris

# IANA zone for trip time in WhatsApp templates (match landing SERVICE_TZ, e.g. Europe/Paris)
BOOKING_DISPLAY_TIMEZONE=Europe/Paris

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec...
# Stripe Connect (driver Express onboarding)
# Email button → API_PUBLIC_ORIGIN/api/public/stripe/onboarding?token=… (fresh Stripe link on each click).
# STRIPE_CONNECT_RETURN_URL — landing after onboarding (default: LANDING_ORIGIN)
# STRIPE_BUSINESS_PROFILE_URL — Stripe Express business profile URL (default: LANDING_ORIGIN)
# STRIPE_CONNECT_DEFAULT_COUNTRY=FR

# Meta WhatsApp Cloud API (webhook + send)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Must match approved template locale in Meta (e.g. fr, fr_FR, en)
# WHATSAPP_TEMPLATE_TRIP_OFFER_LANG=fr
# WHATSAPP_TEMPLATE_TRIP_OFFER_DRIVER=trip_offer_driver

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Required for transactional emails (bookings, security requests, driver Stripe onboarding).
# Security landing admin notifications are sent to SMTP_USER.
# Landing sends locale: "en" | "fr" on POST /api/security-request and POST /api/public/bookings

# Marketplace pricing (Europe/Paris for holiday/night; comma-separated YYYY-MM-DD)
# PRICING_HOLIDAY_DATES=2026-12-25,2026-01-01
# PRICING_COUNT_SUNDAYS_AS_HOLIDAY=true
# PRICING_NIGHT_START_HOUR=22
# PRICING_NIGHT_END_HOUR=6
# Default partner commission when org has none (percent)
# DEFAULT_PLATFORM_COMMISSION_PERCENT=20
# Legacy alias used in older code paths:
# PLATFORM_COMMISSION_PERCENT=20