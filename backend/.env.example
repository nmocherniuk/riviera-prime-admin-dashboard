# Copy to .env and adjust.
DATABASE_URL=postgresql://postgres:password@localhost:5432/aurevia_admin

JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long
ADMIN_EMAIL=admin@aurevia.local
# Use either plain password for local dev:
ADMIN_PASSWORD=changeme
# Or bcrypt hash (preferred):
# ADMIN_PASSWORD_HASH=$2b$10$...
# If DB has ADMIN user, DB auth is used first.

FRONTEND_ORIGIN=http://localhost:5173
LANDING_ORIGIN=http://localhost:3000
# Optional override: comma-separated list replaces FRONTEND_ORIGIN / LANDING_ORIGIN for CORS.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://booking.example.com
PORT=5000

# Optional: if set, public landing must send header x-public-booking-key: <same value>
# PUBLIC_BOOKING_API_KEY=

# Optional: polling interval for driver-deadline fallback watcher (min 5000 ms)
# DRIVER_DEADLINE_WATCH_INTERVAL_MS=60000

# IANA zone for trip time in WhatsApp templates (match landing SERVICE_TZ, e.g. Europe/Paris)
BOOKING_DISPLAY_TIMEZONE=Europe/Paris

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec...

# Meta WhatsApp Cloud API (webhook + send)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=