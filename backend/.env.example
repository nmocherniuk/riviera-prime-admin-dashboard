# Copy to .env and adjust. Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpass',10))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-long

ADMIN_EMAIL=admin@aurevia.local
# Dev: plain password OR set ADMIN_PASSWORD_HASH (bcrypt) for safer local setup
ADMIN_PASSWORD=changeme

FRONTEND_ORIGIN=http://localhost:5173
PORT=5000
